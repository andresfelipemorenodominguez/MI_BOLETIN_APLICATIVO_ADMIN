# Base de datos (Supabase u otro PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Obligatoria: sesiones Flask (genera una cadena larga aleatoria)
SECRET_KEY=

# Puerto HTTP al ejecutar `python app.py` (Docker/README usan 5005)
PORT=5005

# URL pública de la app (enlaces en correos, ej. recuperación de contraseña)
PUBLIC_BASE_URL=http://127.0.0.1:5005

# SMTP (Gmail con contraseña de aplicación)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
# Opcional; si no se define, se usa "MiBoletín <EMAIL_USER>"
EMAIL_FROM=
